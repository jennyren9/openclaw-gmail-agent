# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Primary Gmail Account (v1 only supports one account)
PRIMARY_GMAIL_ACCOUNT=renjing99@gmail.com

# Daily Digest Configuration
DIGEST_RECIPIENT_EMAIL=renjing99@gmail.com
DIGEST_SCHEDULE=0 8 * * *
DIGEST_TIMEZONE=America/Los_Angeles

# Email Lookback (in hours)
EMAIL_LOOKBACK_HOURS=24

# Database
DATABASE_PATH=./data/openclaw.db

# Feature Flags
MARK_LOW_PRIORITY_AS_READ=true
MARK_FYI_AS_READ_AFTER_DIGEST=false
MARK_ACTION_ITEMS_AS_READ=false
DRY_RUN=false

# Optional: AI/summarization service (for future use)
# OPENAI_API_KEY=
# CLAUDE_API_KEY=
